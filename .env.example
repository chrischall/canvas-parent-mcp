CANVAS_BASE_URL=https://cms.instructure.com
CANVAS_NAME=cms

# Username/password (recommended).
# Most schools have disabled personal-access-token creation. This mode auto-
# logs-in at startup and silently re-mints session cookies on 401, so you
# never need to re-bootstrap. Direct Canvas accounts only — no SSO/2FA.
CANVAS_USERNAME=
CANVAS_PASSWORD=

# === Advanced alternatives — pick ONE of the modes above OR below ===

# Personal access token. Simplest if your admin allows it.
# Generate from Canvas: Account → Settings → "+ New Access Token".
# CANVAS_TOKEN=

# OAuth (bootstrap via the mobile QR flow when SSO accounts can't use u/p):
#   1. In Canvas web, open Account -> QR for Mobile Login.
#   2. Decode the QR with any reader (the result is an https://sso.canvaslms.com URL).
#   3. Run: canvas-parent-mcp-qr-login "<qr-url>" >> .env
# CANVAS_CLIENT_ID=
# CANVAS_CLIENT_SECRET=
# CANVAS_REFRESH_TOKEN=
