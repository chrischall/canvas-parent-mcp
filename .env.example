CANVAS_BASE_URL=https://cms.instructure.com
CANVAS_NAME=cms

# Personal access token (recommended).
# Generate from Canvas: Account → Settings → "+ New Access Token".
CANVAS_TOKEN=

# Or, username/password (most convenient when admins have disabled tokens).
# The MCP auto-logs-in at startup and auto-renews cookies on 401.
# CANVAS_USERNAME=
# CANVAS_PASSWORD=

# Or, session cookie (precomputed, no auto-renewal — re-run the CLI when it expires):
#   canvas-parent-mcp-login -b https://cms.instructure.com -u me@example.com >> .env
# CANVAS_COOKIE=

# Or, OAuth (advanced; bootstrap via the mobile QR flow):
#   1. In Canvas web, open Account -> QR for Mobile Login.
#   2. Decode the QR with any reader (the result is an https://sso.canvaslms.com URL).
#   3. Run: canvas-parent-mcp-qr-login "<qr-url>" >> .env
# CANVAS_CLIENT_ID=
# CANVAS_CLIENT_SECRET=
# CANVAS_REFRESH_TOKEN=
